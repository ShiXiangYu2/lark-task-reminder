{
  "name": "lark-task-reminder",
  "version": "1.0.0",
  "description": "飞书任务提醒 Agent - 自动同步飞书任务并智能提醒",
  "type": "module",
  "bin": {
    "lark-task-reminder": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "ci": "npm run lint && npm run test && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "lark",
    "feishu",
    "task",
    "reminder",
    "cli",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.5.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}